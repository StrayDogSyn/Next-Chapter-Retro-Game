# dependencies
/node_modules
node_modules/
**/node_modules/
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# regenerated every build by scripts/copy-portal-assets.mjs (prebuild hook);
# repo-root index.html/styles/ stay the single source of truth
/public/portal/

# production
/build

# NOTE: /out/ is ignored because the CI pipeline builds and deploys the
# static export to GitHub Pages automatically; build artifacts should not
# be committed to the main source branch.

# misc
.DS_Store
Thumbs.db
*.pem

# editor metadata
.vscode/
.idea/
*.swp

# debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# local env files
.env*.local
python-service/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python service
python-service/.venv/
python-service/__pycache__/

# asset pipeline temp + ground-truth snapshot (regenerated)
.asset-tmp/
.asset-tmp/*
.asset-tmp-inspect/*
.asset-tmp-vitest/*
.github/*
STATUS.txt

# duplicate backup of assets/, not source of truth
/assets.zip

# portable node runtime (local tooling, not project code)
node-portable/

# python bytecode from scripts
scripts/__pycache__/
**/__pycache__/
